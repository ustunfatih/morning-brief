# Copy to .env and fill in real values
GEMINI_API_KEY=
# Optional fallback name supported by the script:
# GOOGLE_API_KEY=
# Optional model override (default in code: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
# Optional image model for daily hero generation
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Optional number of pre-generated headers per mood level (default 5)
HEADER_POOL_SIZE=5
# Optional target dimensions for normalized mood headers
HEADER_TARGET_WIDTH=1360
HEADER_TARGET_HEIGHT=440
# Optional Todoist integration (tasks/events section)
TODOIST_API_TOKEN=
TODOIST_FILTER="overdue | today"
TODOIST_MAX_ITEMS=10
TODOIST_CACHE_TTL_MIN=10
# Email rendering profile (default: email-safe + offwhite-slate)
EMAIL_RENDER_MODE=email-safe
THEME_PROFILE=offwhite-slate
# Optional payload warning threshold in bytes (default: 102400)
# EMAIL_HTML_BUDGET_BYTES=102400
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
